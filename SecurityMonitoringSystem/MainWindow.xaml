<Window x:Class="SecurityMonitoringSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:SecurityMonitoringSystem.ViewModels"
        Title="6G Security &amp; Monitoring System" Height="720" Width="1080"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PanelBrush}">
            <DockPanel>
                <!-- Logout at bottom -->
                <Border DockPanel.Dock="Bottom" Margin="10,10,10,20">
                    <Button x:Name="btnLogout" Content="⏻  Log Out" Height="40"
                            Background="#3A1A1A" Foreground="#FF6B6B"
                            HorizontalContentAlignment="Left" Padding="20,0,0,0"
                            Click="Logout_Click"/>
                </Border>
                <!-- Nav items -->
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="6G SECURE" Foreground="{StaticResource AccentBrush}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    
                    <Button Content="Dashboard" Command="{Binding NavigateDashboardCmd}" Margin="10,5" Height="40" Background="Transparent" Foreground="{StaticResource TextBrush}" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                    <Button Content="Network Monitoring" Command="{Binding NavigateNetworkCmd}" Margin="10,5" Height="40" Background="Transparent" Foreground="{StaticResource TextBrush}" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                    <Button x:Name="btnAccessControl" Content="Access Control" Command="{Binding NavigateAccessCmd}" Margin="10,5" Height="40" Background="Transparent" Foreground="{StaticResource TextBrush}" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                    <Button Content="Data Encryption" Command="{Binding NavigateEncryptionCmd}" Margin="10,5" Height="40" Background="Transparent" Foreground="{StaticResource TextBrush}" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                    <Button Content="Activity Logging" Command="{Binding NavigateLogsCmd}" Margin="10,5" Height="40" Background="Transparent" Foreground="{StaticResource TextBrush}" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                    <Button x:Name="btnThreatDetection" Content="Threat Detection" Command="{Binding NavigateThreatsCmd}" Margin="10,5" Height="40" Background="Transparent" Foreground="{StaticResource TextBrush}" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header section -->
            <Border Grid.Row="0" BorderBrush="{StaticResource PanelBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock Text="Infrastructure Security Monitoring" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="txtHeaderRole" Text="Role: Admin" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Ellipse Width="35" Height="35" Fill="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Dynamic View -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
            
        </Grid>
    </Grid>
</Window>
