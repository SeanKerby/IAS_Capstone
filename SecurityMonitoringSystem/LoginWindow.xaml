<Window x:Class="SecurityMonitoringSystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Login" Height="400" Width="400"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterScreen">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="6G SECURE" Foreground="{StaticResource AccentBrush}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="System Authentication" Foreground="{StaticResource TextBrush}" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            
            <TextBlock Text="Username" Margin="0,5"/>
            <TextBox x:Name="txtUsername" Height="30" Margin="0,0,0,15"/>
            
            <TextBlock Text="Password" Margin="0,5"/>
            <PasswordBox x:Name="pwdBox" Height="30" Margin="0,0,0,25"/>
            
            <Button Content="LOGIN" Height="40" Click="Login_Click"/>
        </StackPanel>
    </Grid>
</Window>
