<UserControl x:Class="SecurityMonitoringSystem.Views.ActivityLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Activity Logging &amp; Audit Trail" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Export CSV" HorizontalAlignment="Right" Width="100" Height="35" Background="{StaticResource SuccessGreenBrush}" Click="Export_Click"/>
        </Grid>

        <!-- Filters -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" Margin="0,0,0,20" CornerRadius="8" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Search Logs:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Width="250" VerticalAlignment="Center"/>
                <TextBlock Text="Filter by Module:" VerticalAlignment="Center" Margin="20,0,10,0"/>
                <ComboBox Width="150" SelectedIndex="0" VerticalAlignment="Center">
                    <ComboBoxItem Content="All Modules"/>
                    <ComboBoxItem Content="Access Control"/>
                    <ComboBoxItem Content="Threat Detection"/>
                    <ComboBoxItem Content="Encryption"/>
                </ComboBox>
                <Button Content="Search" Width="80" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Log Table -->
        <DataGrid Grid.Row="2" x:Name="LogsDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="150"/>
                <DataGridTextColumn Header="User" Binding="{Binding User}" Width="100"/>
                <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="150"/>
                <DataGridTextColumn Header="Action/Detail" Binding="{Binding Action}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
