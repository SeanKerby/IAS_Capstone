<UserControl x:Class="SecurityMonitoringSystem.Views.AccessControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Access Control &amp; User Management" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- User List -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" Margin="0,0,10,0" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Active Users Directory" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" x:Name="UsersDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100"/>
                            <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin}" Width="150"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Add/Edit User Form -->
            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" Margin="10,0,0,0" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Manage User" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Username" Margin="0,5"/>
                    <TextBox x:Name="txtUsername" Height="30"/>
                    
                    <TextBlock Text="Password" Margin="0,5"/>
                    <PasswordBox x:Name="pwdBox" Height="30"/>
                    
                    <TextBlock Text="Role" Margin="0,15,0,5"/>
                    <ComboBox x:Name="cmbRole" Height="30" SelectedIndex="0">
                        <ComboBoxItem Content="Administrator"/>
                        <ComboBoxItem Content="User"/>
                        <ComboBoxItem Content="Guest"/>
                    </ComboBox>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                        <Button Content="Delete" Background="{StaticResource AlertRedBrush}" Width="80" Margin="0,0,10,0" Click="Delete_Click"/>
                        <Button Content="Save" Width="80" Click="Save_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
